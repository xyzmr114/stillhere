DATABASE_URL=postgresql://postgres.[ref]:[password]@host:5432/postgres
JWT_SECRET=changeme
REDIS_URL=redis://redis:6379
CELERY_BROKER=redis://redis:6379/0
BASE_URL=https://yourdomain.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
SNS_SENDER_ID=StillHere

# --- Push Notifications ---
# Option A: Firebase (cloud)
PUSH_PROVIDER=firebase
FIREBASE_CRED_PATH=firebase/your-adminsdk.json
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
FIREBASE_VAPID_KEY=

# Option B: Web Push (self-hosted, no Firebase needed)
# PUSH_PROVIDER=webpush
# WEBPUSH_VAPID_PUBLIC_KEY=
# WEBPUSH_VAPID_PRIVATE_KEY=
# WEBPUSH_VAPID_EMAIL=you@example.com

# --- Email ---
# Option A: Resend (cloud)
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=Still Here <noreply@yourdomain.com>

# Option B: SMTP
# Set SMTP_PRESET to auto-fill host/port, or set SMTP_HOST manually.
# Presets: brevo | resend | gmail | mailgun | mailjet | sendgrid | zoho | cpanel | local
#
# EMAIL_PROVIDER=smtp
# SMTP_PRESET=brevo
# SMTP_USER=your-login@example.com
# SMTP_PASSWORD=
# EMAIL_FROM=Still Here <noreply@yourdomain.com>
#
# For cPanel/DirectAdmin: set SMTP_PRESET=cpanel and SMTP_HOST=mail.yourdomain.com
# For Gmail: use an App Password (not your account password)
# For local Postfix: SMTP_PRESET=local, leave SMTP_USER blank

# --- Auth (optional) ---
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=

# --- SMS & Voice (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SID=
DEMO_SMS_TO=

# --- Payments (optional) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
