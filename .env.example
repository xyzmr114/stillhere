# ─── Required ────────────────────────────────────────────────────────────────

DATABASE_URL=postgresql://postgres:[password]@localhost:5432/postgres
JWT_SECRET=change-me-use-a-long-random-string
REDIS_URL=redis://redis:6379
CELERY_BROKER=redis://redis:6379/0
BASE_URL=https://yourdomain.com

# ─── Push Notifications ───────────────────────────────────────────────────────
# Self-hosted (no Firebase): generate keys with `vapid --gen`
PUSH_PROVIDER=webpush
WEBPUSH_VAPID_PUBLIC_KEY=
WEBPUSH_VAPID_PRIVATE_KEY=
WEBPUSH_VAPID_EMAIL=you@example.com

# Cloud (Firebase): set PUSH_PROVIDER=firebase and fill these in
# PUSH_PROVIDER=firebase
# FIREBASE_CRED_PATH=firebase/your-adminsdk.json
# FIREBASE_API_KEY=
# FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# FIREBASE_PROJECT_ID=your-project
# FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
# FIREBASE_MESSAGING_SENDER_ID=
# FIREBASE_APP_ID=
# FIREBASE_MEASUREMENT_ID=
# FIREBASE_VAPID_KEY=

# ─── Email ────────────────────────────────────────────────────────────────────
# Self-hosted SMTP: set SMTP_PRESET to your provider (see docs/env-reference.md)
# Presets: brevo | gmail | mailgun | mailjet | sendgrid | zoho | cpanel | local
EMAIL_PROVIDER=smtp
SMTP_PRESET=brevo
SMTP_USER=your-login@example.com
SMTP_PASSWORD=
EMAIL_FROM=Still Here <noreply@yourdomain.com>
# SMTP_HOST=        # only needed for cpanel — set to mail.yourdomain.com
# SMTP_PORT=        # leave blank if using a preset
# SMTP_TLS=true

# Cloud (Resend): set EMAIL_PROVIDER=resend and fill in the key
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=
# EMAIL_FROM=Still Here <noreply@yourdomain.com>

# ─── SMS & Voice (Twilio) ─────────────────────────────────────────────────────
# Required for SMS escalation and welfare calls. No self-hosted alternative.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SID=
DEMO_SMS_TO=

# ─── Auth (optional) ─────────────────────────────────────────────────────────
# Enables Google / social login. Leave blank to use email+password only.
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=

# ─── Payments (optional) ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
